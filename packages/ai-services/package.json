{
  "name": "@afg/ai-services",
  "version": "0.1.0",
  "private": true,
  "description": "AI/ML inference services: Fraud, AML, Sanctions, Credit, Conversational AI, Document Intelligence, NBA, Complaints",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "test": "vitest run",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@afg/shared-types": "*",
    "@afg/platform-services": "*"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  }
}
