{
  "name": "@afg/shared-types",
  "version": "0.1.0",
  "private": true,
  "description": "Shared domain types and interfaces for the AFG AI/ML Banking Platform",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "test": "vitest run",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  }
}
