{
  "name": "afg-ai-banking-platform",
  "version": "0.1.0",
  "private": true,
  "description": "AFG Enterprise AI/ML Banking Platform - Cloud-agnostic, multi-region intelligent platform",
  "workspaces": [
    "packages/shared-types",
    "packages/platform-services",
    "packages/ai-services",
    "packages/data-layer",
    "packages/integration-layer",
    "packages/infrastructure"
  ],
  "scripts": {
    "build": "tsc --build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .ts",
    "clean": "rimraf packages/*/dist"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "fast-check": "^3.15.0",
    "rimraf": "^5.0.5",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
